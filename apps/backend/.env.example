# Amir ERP backend — environment template
# Author: Amir Saoudi
# Copy to `.env` and adjust as needed.

NODE_ENV=development
PORT=3000
APP_NAME="Amir ERP"
APP_AUTHOR="Amir Saoudi"
APP_AUTHOR_EMAIL="amirsaoudi620@gmail.com"
APP_BASE_URL=http://localhost:3000
WEB_BASE_URL=http://localhost:8080

# PostgreSQL
DATABASE_URL=postgresql://amir:amir@localhost:5432/amir_erp?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change-me-amir-access-secret-please-set-a-long-random-string
JWT_REFRESH_SECRET=change-me-amir-refresh-secret-please-set-a-long-random-string
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=amir
S3_SECRET_KEY=amirminio
S3_BUCKET=amir-erp
S3_USE_SSL=false

# Meilisearch
MEILI_HOST=http://localhost:7700
MEILI_KEY=amir-meili-master-key-change-me

# Mailer (Mailhog locally)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Amir ERP <noreply@amir-erp.local>"

# Security
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,http://localhost:5173

# Telemetry
LOG_LEVEL=info
ENABLE_METRICS=true
