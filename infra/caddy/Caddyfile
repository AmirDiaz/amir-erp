# Amir ERP — Caddy reverse proxy
# Author: Amir Saoudi
#
# In production, replace `:80` with your domain (e.g. `app.example.com`)
# and Caddy will provision Let's Encrypt automatically.

{
  email amirsaoudi620@gmail.com
  admin off
}

:80 {
  encode zstd gzip

  # API — backend service
  handle /api/* {
    reverse_proxy host.docker.internal:3000
  }

  # WebSocket
  handle /socket.io/* {
    reverse_proxy host.docker.internal:3000
  }

  # Grafana (observability)
  handle /grafana/* {
    uri strip_prefix /grafana
    reverse_proxy grafana:3000
  }

  # MinIO console
  handle /storage-console/* {
    uri strip_prefix /storage-console
    reverse_proxy minio:9001
  }

  # Default — Flutter web build
  handle {
    root * /srv
    try_files {path} /index.html
    file_server
  }
}
